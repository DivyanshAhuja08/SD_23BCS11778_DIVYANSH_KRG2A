          <mxGeometry height="183" width="500" x="4243.67" y="9727" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-23" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#001DBC;fillColor=#FFE6CC;align=left;verticalAlign=middle;rounded=0;fontColor=#ffffff;" value="&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;These three things are part of WebRTC signaling. They are used to establish the connection before audio/video streaming starts in WebRTC.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The signaling process exchanges:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;SDP Offer&lt;br&gt;SDP Answer&lt;br&gt;ICE Candidates&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Together they allow two peers (browser and media server) to discover each other, agree on parameters, and find the best network path.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Let’s explain each one clearly.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;1. SDP Offer&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;SDP = Session Description Protocol&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;An SDP Offer is the first message sent by the browser to describe how it wants to communicate.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;It tells the other side:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;supported video codecs&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;supported audio codecs&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;transport protocol&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;encryption methods&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;media types&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example simplified SDP Offer:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;v=0&lt;br&gt;o=- 46117392 2 IN IP4 127.0.0.1&lt;br&gt;s=WebRTC Session&lt;br&gt;t=0 0&lt;br&gt;m=video 9 UDP/TLS/RTP/SAVPF 96&lt;br&gt;a=rtpmap:96 H264/90000&lt;br&gt;m=audio 9 UDP/TLS/RTP/SAVPF 111&lt;br&gt;a=rtpmap:111 opus/48000/2&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Meaning:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;video codec = H264&lt;br&gt;audio codec = OPUS&lt;br&gt;transport = RTP over UDP&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Flow:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Browser → Signaling Server → Media Server&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;2. SDP Answer&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The SDP Answer is the response from the media server.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;It tells the browser:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;which codecs were accepted&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;which ports to use&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;which encryption methods to use&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example simplified SDP Answer:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;v=0&lt;br&gt;o=- 46117393 2 IN IP4 10.0.0.5&lt;br&gt;s=WebRTC Session&lt;br&gt;t=0 0&lt;br&gt;m=video 54000 UDP/TLS/RTP/SAVPF 96&lt;br&gt;a=rtpmap:96 H264/90000&lt;br&gt;m=audio 54002 UDP/TLS/RTP/SAVPF 111&lt;br&gt;a=rtpmap:111 opus/48000/2&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Meaning:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;video port = 54000&lt;br&gt;audio port = 54002&lt;br&gt;codec accepted = H264 + OPUS&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Flow:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Media Server → Signaling Server → Browser&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;After Offer + Answer, both sides now know:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;codecs&lt;br&gt;media types&lt;br&gt;transport protocols&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;But they still don’t know how to reach each other over the network.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;That’s where ICE comes in.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;3. ICE Candidates&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;ICE = Interactive Connectivity Establishment&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;ICE candidates are possible network addresses where the peer can be reached.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Each side sends multiple candidates.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;candidate:1 1 UDP 2122260223 192.168.1.5 54000 typ host&lt;br&gt;candidate:2 1 UDP 1686052607 34.23.45.10 54001 typ srflx&lt;br&gt;candidate:3 1 UDP 1518280447 3.14.56.78 3478 typ relay&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Types of candidates:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;Type&lt;/font&gt;&lt;/th&gt;&lt;th&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;Meaning&lt;/font&gt;&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;host&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;local IP&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;srflx&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;public IP discovered via STUN&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;relay&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;TURN server relay&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Protocols involved:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;STUN&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;TURN&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The browser and media server test these candidates and choose the best path.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Usually:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;UDP direct connection&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;If direct connection fails:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;TURN relay&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;4. Complete Signaling Flow&lt;/font&gt;&lt;/h1&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;1. Browser creates SDP Offer&lt;br&gt;2. Offer → Signaling Server → Media Server&lt;br&gt;3. Media Server creates SDP Answer&lt;br&gt;4. Answer → Signaling Server → Browser&lt;br&gt;5. Both sides exchange ICE Candidates&lt;br&gt;6. Best network path selected&lt;br&gt;7. WebRTC connection established&lt;br&gt;8. Media packets start flowing&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;After step 7:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;audio/video streams start&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The signaling server is no longer needed for media transmission.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;5. Simple Diagram&lt;/font&gt;&lt;/h1&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Browser&lt;br&gt;   │&lt;br&gt;   │ SDP Offer&lt;br&gt;   ▼&lt;br&gt;Signaling Server&lt;br&gt;   │&lt;br&gt;   ▼&lt;br&gt;Media Server&lt;br&gt;   │&lt;br&gt;   │ SDP Answer&lt;br&gt;   ▼&lt;br&gt;Browser&lt;br&gt;&lt;br&gt;ICE candidates exchanged&lt;br&gt;       │&lt;br&gt;       ▼&lt;br&gt;WebRTC connection established&lt;br&gt;       │&lt;br&gt;       ▼&lt;br&gt;Media packets (audio/video)&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;✅ Simple summary&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;SDP Offer → &quot;Here is how I can communicate&quot;&lt;br&gt;SDP Answer → &quot;Here is what I accept&quot;&lt;br&gt;ICE Candidates → &quot;Here is where you can reach me&quot;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Together they allow WebRTC peers to negotiate the connection and establish a real-time media path.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="5427" width="2469" x="231" y="14368" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-27" edge="1" parent="1" source="xAxiiUeme6yhLJrTTKhS-24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;strokeWidth=4;" target="xAxiiUeme6yhLJrTTKhS-15">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFCCE6;gradientColor=#b3b3b3;strokeColor=#666666;gradientDirection=east;" value="&lt;font style=&quot;font-size: 60px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;SIGNALING SERVER&lt;/b&gt;&lt;br&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="260" width="886" x="2532" y="9900" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-25" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;Te&lt;span style=&quot;background-color: transparent;&quot;&gt;forward SDP offer&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;forward SDP answer&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;forward ICE candidates&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;manage sessions&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;authenticate clients&lt;/span&gt;xt&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="430" width="509" x="2720" y="9539" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-29" edge="1" parent="1" source="xAxiiUeme6yhLJrTTKhS-24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=0.996;entryY=0.583;entryDx=0;entryDy=0;entryPerimeter=0;strokeColor=default;strokeWidth=4;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;endArrow=classic;" target="xAxiiUeme6yhLJrTTKhS-7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-30" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#001DBC;fillColor=#FFE6CC;align=left;verticalAlign=middle;rounded=0;fontColor=#ffffff;" value="&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;ICE candidates are generated by the WebRTC endpoints themselves — usually the browser (client) and the media server. The signaling server only transports them between peers.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Protocol involved:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;WebRTC&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;1. What ICE Candidates Are&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;ICE (Interactive Connectivity Establishment) candidates are possible network addresses where a peer can receive media packets.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Each candidate represents a potential path for the connection.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example candidate:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;candidate:1 1 UDP 2122260223 192.168.1.5 54000 typ host&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;It includes:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;IP address&lt;br&gt;port&lt;br&gt;transport protocol&lt;br&gt;priority&lt;br&gt;candidate type&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;2. Who Generates ICE Candidates&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Two entities generate them.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;1️⃣ Browser (Client)&lt;/font&gt;&lt;/h3&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The browser gathers candidates using the WebRTC API.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example code:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;RTCPeerConnection&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The browser automatically collects:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;local IP address&lt;br&gt;public IP address&lt;br&gt;relay address&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;These are sent as ICE candidates.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;hr&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;2️⃣ Media Server&lt;/font&gt;&lt;/h3&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The media server also gathers ICE candidates for its network interfaces.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;It generates candidates such as:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;public server IP&lt;br&gt;internal datacenter IP&lt;br&gt;TURN relay address&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;These are returned to the browser.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;3. Role of STUN and TURN&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;While gathering ICE candidates, WebRTC uses these protocols:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;STUN&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;TURN&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;STUN&lt;/font&gt;&lt;/h3&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Helps discover the public IP address of a device behind NAT.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Local IP → 192.168.1.5&lt;br&gt;Public IP → 34.12.55.21&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;TURN&lt;/font&gt;&lt;/h3&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Used when direct connection is impossible.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;It provides a relay server.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Browser → TURN Server → Media Server&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;4. How ICE Candidates Are Sent&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;ICE candidates are exchanged through the signaling server.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Flow:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Browser&lt;br&gt;   ↓ candidate&lt;br&gt;Signaling Server&lt;br&gt;   ↓&lt;br&gt;Media Server&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;and&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Media Server&lt;br&gt;   ↓ candidate&lt;br&gt;Signaling Server&lt;br&gt;   ↓&lt;br&gt;Browser&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The signaling server only forwards them.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;5. Candidate Types&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Three main candidate types exist.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;Host Candidate&lt;/font&gt;&lt;/h3&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Local IP address&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;192.168.1.10&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;Server Reflexive Candidate&lt;/font&gt;&lt;/h3&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Discovered via STUN.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;public IP address&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h3&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;Relay Candidate&lt;/font&gt;&lt;/h3&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Provided by TURN.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Example:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;TURN server relay&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;6. Candidate Testing&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;After exchanging candidates, WebRTC performs connectivity checks.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;It tests:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;host → host&lt;br&gt;host → public&lt;br&gt;relay → relay&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;The best working path is selected.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Usually:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;direct UDP connection&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;7. Final Media Path&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Once ICE checks succeed:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Browser&lt;br&gt;   ↓ UDP&lt;br&gt;Media Server&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Media packets (audio/video) begin flowing.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;hr&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;✅ Simple Summary&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;ICE candidates are created by:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;pre&gt;&lt;code&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;Browser → gathers local/public network addresses&lt;br&gt;Media Server → gathers server network addresses&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;font style=&quot;font-size: 30px; color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;They are exchanged via the signaling server to find the best network path for WebRTC media streaming.&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="4955" width="2003" x="3200" y="14757" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-31" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;AFTER ALL THING DONE IT BYPASS THE SIGNALLING SERVER AND DIRECT VIDEO AND AUDIO GO TO MEDIA SERVER&amp;nbsp;&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="297" width="304" x="2823" y="10190" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-44" edge="1" parent="1" source="xAxiiUeme6yhLJrTTKhS-32" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=4;" target="xAxiiUeme6yhLJrTTKhS-43">
