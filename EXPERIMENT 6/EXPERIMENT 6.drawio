        <mxCell id="xAxiiUeme6yhLJrTTKhS-18" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p data-start=&quot;1548&quot; data-end=&quot;1590&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;Audio and video streams arrive separately.&lt;/font&gt;&lt;/b&gt;&lt;/p&gt;&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;p data-start=&quot;1592&quot; data-end=&quot;1638&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;The media server aligns them using timestamps.&lt;/font&gt;&lt;/b&gt;&lt;/p&gt;&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;p data-start=&quot;1640&quot; data-end=&quot;1648&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;Example:&lt;/font&gt;&lt;/b&gt;&lt;/p&gt;&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;pre class=&quot;overflow-visible! px-0!&quot; data-start=&quot;1650&quot; data-end=&quot;1717&quot;&gt;&lt;div class=&quot;relative w-full my-4&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;relative&quot;&gt;&lt;div class=&quot;h-full min-h-0 min-w-0&quot;&gt;&lt;div class=&quot;h-full min-h-0 min-w-0&quot;&gt;&lt;div class=&quot;border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl&quot;&gt;&lt;div class=&quot;h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback&quot;&gt;&lt;div class=&quot;pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1&quot;&gt;&lt;/div&gt;&lt;div class=&quot;pt-3&quot;&gt;&lt;div class=&quot;relative z-0 flex max-w-full&quot;&gt;&lt;div id=&quot;code-block-viewer&quot; dir=&quot;ltr&quot; class=&quot;q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy&quot;&gt;&lt;div class=&quot;cm-scroller&quot;&gt;&lt;div class=&quot;cm-content q9tKkq_readonly&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;span&gt;audio frame → timestamp 10.2s&lt;/span&gt;&lt;br&gt;&lt;span&gt;video frame → timestamp 10.2s&lt;/span&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/pre&gt;" vertex="1">
