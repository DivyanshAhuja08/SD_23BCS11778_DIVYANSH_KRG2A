        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-33" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;p data-start=&quot;331&quot; data-end=&quot;354&quot;&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;YouTube-optimized DASH:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p data-start=&quot;331&quot; data-end=&quot;354&quot;&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Segment size: &lt;/span&gt;&lt;span data-start=&quot;371&quot; data-end=&quot;394&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;~1 second (or less)&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p data-start=&quot;331&quot; data-end=&quot;354&quot;&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;End-to-end delay: &lt;/span&gt;&lt;span data-start=&quot;415&quot; data-end=&quot;431&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;8–15 seconds&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; (sometimes lower)&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="200" width="500" x="6520" y="9618" as="geometry" />
        </mxCell>
        <mxCell id="xAxiiUeme6yhLJrTTKhS-34" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;WHOLE VIDEO IS SPLIT IN SMALL PART (5s-6s) VIDEOS AND MAKE THE MANIFEST FILE&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;FOR HLS .m3ud&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b&gt;FOR DASH .mpd&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
